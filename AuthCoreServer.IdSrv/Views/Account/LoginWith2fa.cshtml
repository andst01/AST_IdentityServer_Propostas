@using AuthCoreServer.IdSrv.Quickstart.Account
@model LoginWith2faViewModel

<h2>Autenticação em Dois Fatores</h2>

<p>
    Digite o código gerado pelo seu aplicativo autenticador para confirmar sua identidade.
</p>

<div class="row">
    <div class="col-md-4">
        <form asp-action="LoginWith2fa" method="post" asp-route-returnUrl="@Model.ReturnUrl">
            <input type="hidden" asp-for="ReturnUrl" />
            <input type="hidden" asp-for="RememberMe" />

            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-group">
                <label asp-for="TwoFactorCode">Código de Autenticação</label>
                @* inputmode="numeric" faz o teclado numérico abrir automaticamente no celular *@
                <input asp-for="TwoFactorCode"
                       class="form-control"
                       autocomplete="one-time-code"
                       inputmode="numeric"
                       maxlength="6"
                       placeholder="000000" />
                <span asp-validation-for="TwoFactorCode" class="text-danger"></span>
            </div>

            <br />

            <div class="form-group">
                <div class="checkbox">
                    <label asp-for="RememberMachine">
                        <input asp-for="RememberMachine" />
                        @Html.DisplayNameFor(m => m.RememberMachine)
                        @* Ou apenas: Lembrar este dispositivo *@
                    </label>
                </div>
            </div>

            <br />

            <button type="submit" class="btn btn-primary">Entrar</button>
        </form>
    </div>
</div>

@* Adicione um link para caso o usuário tenha perdido o celular (se você implementar Recovery Codes) *@
<p>
    Não está com seu dispositivo?
    <a asp-action="LoginWithRecoveryCode" asp-route-returnUrl="@Model.ReturnUrl">Entrar com código de recuperação</a>.
</p>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}